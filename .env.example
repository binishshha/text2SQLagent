# =========================
# GEMINI API CONFIG
# =========================

# Get your API key from:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# =========================
# OPTIONAL CONFIG (future use)
# =========================

# Model name (optional override)
GEMINI_MODEL=gemini-2.5-flash

# Request tuning (optional)
REQUEST_DELAY_SECONDS=6
MAX_RETRIES=5

# PostgreSQL settings for the full Agentic Text-to-SQL system.
# Task 2 uses these values to read the live database schema for decomposition.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=text2sql_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Optional single-string alternative used by psycopg if present.
# DATABASE_URL=postgresql://postgres:your_postgres_password_here@localhost:5432/text2sql_agent
